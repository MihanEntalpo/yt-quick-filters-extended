{
  "manifest_version": 3,
  "name": "YouTrack Quick Filters Extended",
  "version": "1.0.0",
  "description": "Quick filters, import/export, and days-in-status tags for YouTrack Agile Boards.",
  "icons": { "128": "icons/logo_128.png" },
  "permissions": ["storage", "tabs"],
  "action": {
    "default_popup": "public/popup.html",
    "default_icon": {
      "128": "icons/logo_128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://*/youtrack/*",
        "https://*/agiles/*",
        "https://*.youtrack.cloud/*"
      ],
      "css": ["dist/content.css"],
      "js": ["dist/content.js"],
      "run_at": "document_idle"
    }
  ]
}
